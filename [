    "code": "/**\n * VideoSaaS Bridge Client\n * \n * Content script 端，通过 BroadcastChannel 与 Service Worker 通信。\n * 每个 tab 使用唯一的 channel key，确保 per-tab 隔离。\n */\n\n(function (global) {\n  'use strict';\n\n  const LOG_PREFIX = '[VideoSaaS-bridge]';\n\n  // 白名单命令：禁止 Content Script 调用未授权的命令\n  const ALLOWED_COMMANDS = new Set([\n    'HLS_GET_VIDEO_DATA',\n    'HLS_GET_SUBTITLE',\n    'HLS_DOWNLOAD',\n    'HLS_PROBE',\n    'HLS_FETCH_MANIFEST',\n    'HLS_FETCH_SEGMENT',\n    'VIDEO_GET_INFO',\n    'VIDEO_DETECT',\n    'TAB_PING',\n    'TAB_INFO'\n  ]);\n\n  // 用于生成唯一请求 ID\n  let _msgCounter = 0;\n  function _nextId() {\n    _msgCounter += 1;\n    return `${Date.now()}_${_msgCounter}`;\n  }\n\n  /**\n   * 生成 per-tab 唯一的 BroadcastChannel key。\n   * Service Worker 可通过 chrome.tabs.onRemoved 拿到 tabId 进行清理。\n   */\n  function _buildChannelKey(tabId) {\n    const id = tabId != null ? tabId : _nextId();\n    return `videosass-bridge-${id}`;\n  }\n\n  class VideoBridge {\n    /**\n     * @param {number|string} [tabId] - 当前 tab 的 ID。\n     *   如果不传，将使用随机 key（用于非 tab 场景，例如 popup）。\n     */\n    constructor(tabId) {\n      this.tabId = tabId;\n      this.channelKey = _buildChannelKey(tabId);\n      this.channel = null;\n      this._listeners = new Map();       // type -> Set<callback>\n      this._pending = new Map();         // id -> { resolve, reject, timer }\n      this._defaultTimeout = 30000;      // 30s 默认超时\n      this._closed = false;\n\n      this._init();\n    }\n\n    _init() {\n      if (typeof BroadcastChannel === 'undefined') {\n        console.error(`${LOG_PREFIX} BroadcastChannel is not supported in this environment.`);\n        return;\n      }\n      try {\n        this.channel = new BroadcastChannel(this.channelKey);\n        this.channel.addEventListener('message', (ev) => this._onMessage(ev)));\n      } catch (err) {\n        console.error(`${LOG_PREFIX} Failed to create BroadcastChannel:`, err);\n      }\n    }\n\n    _onMessage(ev) {\n      const data = ev && ev.data;\n      if (!data || typeof data !== 'object') return;\n\n      // 响应消息（针对某个 request）\n      if (data.type === '__RESPONSE__' && data.id) {\n        const pending = this._pending.get(data.id);\n        if (!pending) return;\n        this._pending.delete(data.id);\n        clearTimeout(pending.timer);\n        if (data.error) {\n          pending.reject(new Error(data.error.message || String(data.error)));\n        } else {\n          pending.resolve(data.payload);\n        }\n        return;\n      }\n\n      // 普通事件广播\n      const set = this._listeners.get(data.type);\n      if (set && set.size > 0) {\n        for (const cb of set) {\n          try { cb(data.payload, data); } catch (e) {\n            console.error(`${LOG_PREFIX} listener error for ${data.type}:`, e);\n          }\n        }\n      }\n    }\n\n    /**\n     * 发送一个事件到 Service Worker（fire-and-forget）。\n     * @param {string} type - 命令名，必须在白名单内。\n     * @param {object} [payload] - 附加数据。\n     */\n    send(type, payload) {\n      if (this._closed) {\n        console.warn(`${LOG_PREFIX} bridge is closed, send ignored:`, type);\n        return;\n      }\n      if (!ALLOWED_COMMANDS.has(type)) {\n        console.error(`${LOG_PREFIX} blocked command (not in whitelist):`, type);\n        return;\n      }\n      if (!this.channel) return;\n      this.channel.postMessage({ type, payload: payload || {} });\n    }\n\n    /**\n     * 发送一个请求，并等待 Promise 风格的响应。\n     * @param {string} type\n     * @param {object} [payload]\n     * @param {number} [timeout]\n     * @returns {Promise<any>}\n     */\n    request(type, payload, timeout) {\n      if (this._closed) {\n        return Promise.reject(new Error('bridge is closed'));\n      }\n      if (!ALLOWED_COMMANDS.has(type)) {\n        return Promise.reject(new Error(`command not allowed: ${type}`));\n      }\n      if (!this.channel) {\n        return Promise.reject(new Error('BroadcastChannel unavailable'));\n      }\n\n      const id = _nextId();\n      const t = typeof timeout === 'number' ? timeout : this._defaultTimeout;\n\n      return new Promise((resolve, reject) => {\n        const timer = setTimeout(() => {\n          if (this._pending.has(id)) {\n            this._pending.delete(id);\n            reject(new Error(`request timeout: ${type} (${t}ms)`));\n          }\n        }, t);\n\n        this._pending.set(id, { resolve, reject, timer });\n        try {\n          this.channel.postMessage({\n            type,\n            id,\n            payload: payload || {}\n          });\n        } catch (err) {\n          this._pending.delete(id);\n          clearTimeout(timer);\n          reject(err);\n        }\n      });\n    }\n\n    /**\n     * 监听某个事件类型。\n     * @param {string} type\n     * @param {(payload: any, message: object) => void} cb\n     * @returns {() => void} 取消监听的函数\n     */\n    on(type, cb) {\n      if (typeof cb !== 'function') return () => {};\n      if (!this._listeners.has(type)) this._listeners.set(type, new Set());\n      this._listeners.get(type).add(cb);\n      return () => this.off(type, cb);\n    }\n\n    off(type, cb) {\n      const set = this._listeners.get(type);\n      if (set) set.delete(cb);\n    }\n\n    /**\n     * 关闭通道，释放资源。\n     */\n    close() {\n      if (this._closed) return;\n      this._closed = true;\n      for (const { reject, timer } of this._pending.values()) {\n        clearTimeout(timer);\n        reject(new Error('bridge closed'));\n      }\n      this._pending.clear();\n      this._listeners.clear();\n      if (this.channel) {\n        try { this.channel.close(); } catch (e) { /* noop */ }\n        this.channel = null;\n      }\n    }\n  }\n\n  VideoBridge.ALLOWED_COMMANDS = ALLOWED_COMMANDS;\n\n  // 兼容 UMD / CommonJS / ES Module\n  if (typeof module !== 'undefined' && module.exports) {\n    module.exports = VideoBridge;\n  } else if (typeof define === 'function' && define.amd) {\n    define(() => VideoBridge);\n  } else {\n    global.VideoBridge = VideoBridge;\n  }\n})(typeof self !== 'undefined' ? self : (typeof window !== 'undefined' ? window : globalThis));\n"
