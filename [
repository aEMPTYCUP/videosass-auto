    "code": "/**\n * VideoSaaS Bridge Server\n * \n * Service Worker / Background 端，监听 per-tab 的 BroadcastChannel，\n * 并提供 Promise 风格的请求-响应能力。\n *\n * 用法：\n *   BridgeServer.start(port => {\n *     port.on('HLS_GET_VIDEO_DATA', async (data) => { ... });\n *   });\n */\n\n(function (global) {\n  'use strict';\n\n  const LOG_PREFIX = '[VideoSaaS-bridge]';\n  const CHANNEL_PREFIX = 'videosass-bridge-';\n  const DEFAULT_TIMEOUT = 30000;\n\n  // 服务端允许注册的命令集合（白名单保护）\n  const _ALLOWED = new Set([\n    'HLS_GET_VIDEO_DATA',\n    'HLS_GET_SUBTITLE',\n    'HLS_DOWNLOAD',\n    'HLS_PROBE',\n    'HLS_FETCH_MANIFEST',\n    'HLS_FETCH_SEGMENT',\n    'VIDEO_GET_INFO',\n    'VIDEO_DETECT',\n    'TAB_PING',\n    'TAB_INFO'\n  ]);\n\n  // ----- 工具 -----\n  let _counter = 0;\n  function _nextId() {\n    _counter += 1;\n    return `${Date.now()}_${_counter}`;\n  }\n\n  function _channelKey(tabId) {\n    return `${CHANNEL_PREFIX}${tabId}`;\n  }\n\n  function _log(...args) {\n    if (typeof console !== 'undefined') {\n      console.log(LOG_PREFIX, ...args);\n    }\n  }\n\n  function _err(...args) {\n    if (typeof console !== 'undefined') {\n      console.error(LOG_PREFIX, ...args);\n    }\n  }\n\n  // ----- 服务端 BridgePort -----\n  /**\n   * 某个 tab 的服务端端口。\n   * @param {number|string} tabId\n   * @param {BroadcastChannel} channel\n   */\n  class BridgePort {\n    constructor(tabId, channel) {\n      this.tabId = tabId;\n      this.channel = channel;\n      this._handlers = new Map();         // type -> async (data, msg) => result\n      this._listeners = new Set();        // raw 消息监听\n      this._closed = false;\n    }\n\n    _onMessage(ev) {\n      if (this._closed) return;\n      const data = ev && ev.data;\n      if (!data || typeof data !== 'object') return;\n\n      // 触发原始监听\n      for (const cb of this._listeners) {\n        try { cb(data); } catch (e) { _err('raw listener error:', e); }\n      }\n\n      const { type, id, payload } = data;\n      if (!type) return;\n\n      // 客户端只允许调用白名单命令\n      if (!_ALLOWED.has(type)) {\n        _err('rejected non-whitelisted command:', type, 'from tab', this.tabId);\n        if (id != null) this._reply(id, null, { message: `command not allowed: ${type}` });\n        return;\n      }\n\n      const handler = this._handlers.get(type);\n      if (!handler) {\n        if (id != null) this._reply(id, null, { message: `no handler for: ${type}` });\n        return;\n      }\n\n      // 异步处理并回复（仅当为请求时）\n      Promise.resolve()\n        .then(() => handler(payload || {}, data))\n        .then((result) => {\n          if (id != null) this._reply(id, result, null);\n        })\n        .catch((err) => {\n          if (id != null) {\n            const message = err && err.message ? err.message : String(err);\n            this._reply(id, null, { message });\n          } else {\n            _err(`handler error for ${type}:`, err);\n          }\n        });\n    }\n\n    _reply(id, payload, error) {\n      if (this._closed || !this.channel) return;\n      try {\n        this.channel.postMessage({\n          type: '__RESPONSE__',\n          id,\n          payload: payload == null ? null : payload,\n          error: error || null\n        });\n      } catch (e) {\n        _err('failed to send response:', e);\n      }\n    }\n\n    /**\n     * 向该 tab 推送事件（fire-and-forget）。\n     */\n    emit(type, payload) {\n      if (this._closed || !this.channel) return;\n      if (!_ALLOWED.has(type)) {\n        _err('refused to emit non-whitelisted type:', type);\n        return;\n      }\n      try {\n        this.channel.postMessage({\n          type,\n          id: _nextId(),\n          payload: payload || {}\n        });\n      } catch (e) {\n        _err('emit failed:', e);\n      }\n    }\n\n    /**\n     * 注册一个命令处理器。\n     * @param {string} type - 命令名（必须在白名单内）。\n     * @param {(data: object, message: object) => Promise<any>|any} handler\n     */\n    on(type, handler) {\n      if (!_ALLOWED.has(type)) {\n        _err('cannot register non-whitelisted command:', type);\n        return;\n      }\n      if (typeof handler !== 'function') return;\n      this._handlers.set(type, handler);\n    }\n\n    off(type) {\n      this._handlers.delete(type);\n    }\n\n    onAny(cb) {\n      if (typeof cb !== 'function') return;\n      this._listeners.add(cb);\n    }\n\n    close() {\n      if (this._closed) return;\n      this._closed = true;\n      this._handlers.clear();\n      this._listeners.clear();\n      if (this.channel) {\n        try { this.channel.close(); } catch (e) { /* noop */ }\n        this.channel = null;\n      }\n    }\n  }\n\n  // ----- BridgeServer -----\n  const BridgeServer = {\n    _ports: new Map(),      // tabId -> BridgePort\n    _setupCallback: null,\n    _started: false,\n\n    /**\n     * 启动服务。Service Worker 启动时调用一次即可。\n     * @param {(port: BridgePort) => void} setup - 当有 tab 端连接时回调。\n     */\n    start(setup) {\n      if (this._started) {\n        _log('BridgeServer already started.');\n        return;\n      }\n      this._started = true;\n      this._setupCallback = typeof setup === 'function' ? setup : null;\n\n      // 监听 tab 关闭，清理资源\n      if (typeof chrome !== 'undefined' && chrome.tabs && chrome.tabs.onRemoved) {\n        chrome.tabs.onRemoved.addListener((tabId) => {\n          this._disconnect(tabId);\n        });\n      }\n      _log('BridgeServer started.');\n    },\n\n    /**\n     * 主动连接一个 tab（一般由 SW 在 content script 注册时调用）。\n     * @param {number|string} tabId\n     * @returns {BridgePort}\n     */\n    connect(tabId) {\n      if (tabId == null) {\n        throw new Error('BridgeServer.connect requires a tabId');\n      }\n      const existing = this._ports.get(tabId);\n      if (existing && !existing._closed) return existing;\n\n      if (typeof BroadcastChannel === 'undefined') {\n        _err('BroadcastChannel is not available in this context.');\n        return null;\n      }\n\n      const key = _channelKey(tabId);\n      const channel = new BroadcastChannel(key);\n      const port = new BridgePort(tabId, channel);\n      this._ports.set(tabId, port);\n\n      channel.addEventListener('message', (ev) => port._onMessage(ev));\n\n      _log('connected to tab', tabId);\n      if (this._setupCallback) {\n        try { this._setupCallback(port); } catch (e) {\n          _err('setup callback error:', e);\n        }\n      }\n      return port;\n    },\n\n    /**\n     * 广播事件到所有已连接的 tab。\n     */\n    broadcast(type, payload) {\n      if (!_ALLOWED.has(type)) {\n        _err('broadcast refused, type not in whitelist:', type);\n        return;\n      }\n      for (const port of this._ports.values()) {\n        if (!port._closed) port.emit(type, payload);\n      }\n    },\n\n    _disconnect(tabId) {\n      const port = this._ports.get(tabId);\n      if (!port) return;\n      _log('disconnecting tab', tabId);\n      port.close();\n      this._ports.delete(tabId);\n    },\n\n    /**\n     * 关闭整个服务。\n     */\n    stop() {\n      for (const tabId of Array.from(this._ports.keys())) {\n        this._disconnect(tabId);\n      }\n      this._started = false;\n      this._setupCallback = null;\n      _log('Bridge