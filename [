    "code": "/**\n * VideoSaaS Service Worker\n * Responsibilities:\n *  - Message bus (chrome.runtime messaging)\n *  - Storage state owner\n *  - declarativeNetRequest rule lifecycle\n *  - BroadcastChannel bridge for cross-context sync\n */\n\nimport { MESSAGE_TYPES, STORAGE_KEYS } from \"../shared/constants.js\";\nimport { Channel } from \"../shared/channel.js\";\nimport { Storage } from \"../shared/storage.js\";\n\nconst channel = new Channel(\"videosaas-bus\");\nconst storage = new Storage();\n\n// ---------- Lifecycle ----------\nchrome.runtime.onInstalled.addListener(async (details) => {\n  console.log(\"[VideoSaaS] onInstalled:\", details.reason);\n  await storage.initDefaults();\n  await refreshDynamicRules();\n});\n\nchrome.runtime.onStartup.addListener(async () => {\n  console.log(\"[VideoSaaS] onStartup\");\n  await refreshDynamicRules();\n});\n\n// ---------- Messaging ----------\nchrome.runtime.onMessage.addListener((message, sender, sendResponse) => {\n  handleMessage(message, sender)\n    .then((response) => sendResponse({ ok: true, data: response }))\n    .catch((err) => sendResponse({ ok: false, error: err.message }));\n  return true; // keep channel open for async response\n});\n\nasync function handleMessage(message, sender) {\n  switch (message.type) {\n    case MESSAGE_TYPES.VIDEO_DETECTED:\n      return onVideoDetected(message.payload, sender);\n    case MESSAGE_TYPES.DOWNLOAD_REQUEST:\n      return onDownloadRequest(message.payload, sender);\n    case MESSAGE_TYPES.STATE_QUERY:\n      return onStateQuery(message.payload);\n    case MESSAGE_TYPES.SETTINGS_UPDATE:\n      return onSettingsUpdate(message.payload);\n    default:\n      throw new Error(`Unknown message type: ${message.type}`);\n  }\n}\n\n// ---------- Handlers ----------\nasync function onVideoDetected(payload, sender) {\n  const taskId = payload.taskId || crypto.randomUUID();\n  const task = {\n    id: taskId,\n    url: payload.url,\n    type: payload.type,\n    tabId: sender.tab?.id,\n    status: \"pending\",\n    createdAt: Date.now(),\n  };\n  await storage.appendTask(task);\n  channel.broadcast({ type: MESSAGE_TYPES.STATE_CHANGED, payload: { task } });\n  return { taskId };\n}\n\nasync function onDownloadRequest(payload) {\n  // Per architecture: do not silently trigger chrome.downloads.\n  // Validate, then return URL for user-initiated save.\n  const task = await storage.getTask(payload.taskId);\n  if (!task) throw new Error(\"Task not found\");\n  if (task.status === \"ready\") {\n    return { url: task.url, filename: payload.filename || suggestFilename(task) };\n  }\n  throw new Error(`Task not ready: ${task.status}`);\n}\n\nasync function onStateQuery(payload) {\n  if (payload.scope === \"tasks\") return storage.getAllTasks();\n  if (payload.scope === \"settings\") return storage.getSettings();\n  return null;\n}\n\nasync function onSettingsUpdate(payload) {\n  await storage.setSettings(payload.settings);\n  await refreshDynamicRules();\n  channel.broadcast({\n    type: MESSAGE_TYPES.SETTINGS_UPDATED,\n    payload: { settings: payload.settings },\n  });\n  return { updated: true };\n}\n\n// ---------- declarativeNetRequest ----------\nasync function refreshDynamicRules() {\n  const settings = await storage.getSettings();\n  const rules = buildRules(settings);\n  const existing = await chrome.declarativeNetRequest.getDynamicRules();\n  await chrome.declarativeNetRequest.updateDynamicRules({\n    removeRuleIds: existing.map((r) => r.id),\n    addRules